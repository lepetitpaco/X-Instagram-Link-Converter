{
  "manifest_version": 2,
  "name": "X & Instagram Link Converter",
  "version": "1.0.4",
  "description": "Convert X/Twitter and Instagram links to privacy-friendly alternatives (fixvx, fixupx, vxtwitter, kkinstagram) with one click.",
  "permissions": [
    "activeTab",
    "clipboardRead",
    "clipboardWrite",
    "storage"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "content_scripts": [
    {
      "matches": ["*://x.com/*", "*://twitter.com/*"],
      "js": ["config.js", "utils.js", "storage.js", "content-x.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://www.instagram.com/*", "*://instagram.com/*"],
      "js": ["config.js", "utils.js", "storage.js", "content-instagram.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "128": "icons/icon128.png"
  },
  "browser_action": {
    "default_icon": "icons/icon128.png",
    "default_title": "Link Converter",
    "default_popup": "popup.html"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "{27ce2a46-7072-4e7e-8537-e7d0b8e4823f}",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    },
    "gecko_android": {
      "strict_min_version": "142.0"
    }
  }
}
